#!/usr/bin/env bash
set -euo pipefail

EXPECTED_MAJOR="22"
RUBY_PLATFORM="$(ruby -e 'print RUBY_PLATFORM')"

for NODE_PREFIX in /usr/local/opt/node@22 /opt/homebrew/opt/node@22; do
  if [[ -x "${NODE_PREFIX}/bin/node" ]]; then
    export PATH="${NODE_PREFIX}/bin:${PATH}"
    break
  fi
done

CURRENT_NODE="$(node -v 2>/dev/null || true)"

if [[ -n "${CURRENT_NODE}" ]] && [[ "${CURRENT_NODE#v}" != ${EXPECTED_MAJOR}.* ]]; then
  echo "Warning: detected Node ${CURRENT_NODE}. Expected Node ${EXPECTED_MAJOR}.x (see .nvmrc)." >&2
fi

if [[ "$(uname -s)" == "Darwin" && "${RUBY_PLATFORM}" == x86_64* ]]; then
  echo "Installing JS deps under x86_64 to match Ruby/Vite runtime (${RUBY_PLATFORM})"
  arch -x86_64 npm ci
else
  echo "Installing JS deps under native architecture (${RUBY_PLATFORM})"
  npm ci
fi
