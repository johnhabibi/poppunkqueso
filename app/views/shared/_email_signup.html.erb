<section class="goop-panel p-6 md:p-8">
  <h3 class="font-display text-2xl uppercase">Get the monthly queso drop</h3>
  <p class="mt-2 max-w-2xl text-sm leading-6 text-ppq-muted">
    One tight email a month: best adds, scene notes, and what to queue next.
    No spam. No content sludge.
  </p>

  <div
    class="mt-5"
    data-vue-component="EmailSignup"
    data-endpoint="<%= email_signups_path %>"
    data-source="<%= local_assigns.fetch(:source, 'site') %>"
  >
    <%= form_with url: email_signups_path, method: :post, class: "flex flex-col gap-3 sm:flex-row" do |f| %>
      <%= f.email_field :email, required: true, placeholder: "you@scene-mail.com", class: "w-full rounded-full border border-ppq-ink/20 px-4 py-3 text-sm" %>
      <%= f.hidden_field :source, value: local_assigns.fetch(:source, 'site') %>
      <%= f.submit "Join the list", class: "rounded-full bg-gradient-to-r from-ppq-yellow to-ppq-red px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white hover:brightness-95" %>
    <% end %>
  </div>
</section>
