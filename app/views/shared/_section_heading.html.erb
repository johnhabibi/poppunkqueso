<div class="mb-8 max-w-3xl">
  <p class="font-display text-sm uppercase tracking-[0.2em] text-ppq-red"><%= eyebrow %></p>
  <h2 class="mt-2 font-display text-3xl uppercase leading-tight text-ppq-ink md:text-4xl"><%= title %></h2>
  <% if body.present? %>
    <p class="mt-3 text-base leading-7 text-ppq-muted"><%= body %></p>
  <% end %>
</div>
