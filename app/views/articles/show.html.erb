<article class="mx-auto max-w-4xl px-4 pb-16 pt-14" data-analytics-view="open_article_post" data-analytics-props="<%= { content_slug: @article.slug }.to_json %>">
  <p class="text-xs uppercase tracking-wide text-ppq-red">Article Template</p>
  <h1 class="mt-3 font-display text-4xl uppercase leading-tight md:text-5xl"><%= @article.title %></h1>
  <p class="mt-4 text-lg leading-8 text-ppq-muted"><%= @article.description %></p>
  <p class="mt-2 text-sm text-ppq-muted">Published <%= @article.date.strftime("%B %-d, %Y") %></p>

  <section class="mt-8 space-y-4 rounded-2xl border border-ppq-ink/10 bg-white p-6">
    <%= render_content_blocks(@article.body) %>
  </section>

  <section class="mt-8 rounded-2xl border border-ppq-ink/10 bg-white p-6">
    <h2 class="font-display text-2xl uppercase">Related pages</h2>
    <ul class="mt-3 space-y-2 text-sm font-semibold">
      <% @article.related_paths.each do |path| %>
        <li><%= link_to path.delete_prefix('/').humanize, path, class: "text-ppq-red underline-offset-2 hover:underline" %></li>
      <% end %>
    </ul>
  </section>
</article>
