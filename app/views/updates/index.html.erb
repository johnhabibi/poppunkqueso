<section class="mx-auto max-w-5xl px-4 pb-16 pt-14">
  <p class="font-display text-sm uppercase tracking-[0.2em] text-ppq-red">Playlist updates</p>
  <h1 class="mt-3 font-display text-4xl uppercase leading-tight md:text-5xl">Recent drops, adds, and rotation notes</h1>
  <p class="mt-5 max-w-3xl text-lg leading-8 text-ppq-muted">
    Every update includes featured tracks, bands added, and context on what changed.
  </p>
  <div class="mt-6 flex flex-wrap gap-3">
    <%= link_to "Open playlist", platform_urls[:spotify], class: "inline-flex items-center justify-center rounded-full border border-ppq-red bg-gradient-to-r from-ppq-yellow to-ppq-red px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition hover:brightness-95", target: "_blank", rel: "noopener", data: { analytics_event: "click_open_playlist_cta", analytics_props: { platform: "spotify", placement: "updates_index_header" }.to_json } %>
    <%= link_to "Read article", article_path("best-newer-pop-punk-songs"), class: "inline-flex items-center justify-center rounded-full border border-ppq-ink px-6 py-3 text-sm font-semibold uppercase tracking-wide text-ppq-ink transition hover:bg-ppq-cream" %>
  </div>
</section>

<section class="mx-auto max-w-5xl space-y-6 px-4 pb-16">
  <% @updates.each do |update| %>
    <%= link_to update_path(update.slug), class: "group block rounded-3xl border border-ppq-ink/10 bg-white p-6 transition hover:border-ppq-red/40 hover:shadow-sm md:p-8" do %>
      <article>
        <p class="text-xs uppercase tracking-wide text-ppq-red"><%= update.date.strftime("%B %-d, %Y") %></p>
        <h2 class="mt-2 font-display text-2xl uppercase md:text-3xl"><%= update.title %></h2>
        <p class="mt-2 text-sm leading-6 text-ppq-muted">
          Featured:
          <span class="font-medium text-ppq-ink"><%= update.featured_tracks.first || "Fresh adds inside" %></span>
        </p>
        <p class="mt-3 text-base leading-7 text-ppq-muted"><%= update.intro %></p>
        <div class="mt-5 flex flex-wrap items-center gap-3 text-sm">
          <% if update.theme.present? %>
            <span class="rounded-full bg-ppq-cream px-3 py-1 text-xs font-medium uppercase tracking-wide text-ppq-muted"><%= update.theme.tr('-', ' ') %></span>
          <% end %>
          <span class="font-semibold text-ppq-red underline-offset-2 group-hover:underline">Read full update</span>
        </div>
      </article>
    <% end %>
  <% end %>
</section>

<section class="mx-auto max-w-5xl px-4 pb-16">
  <div class="goop-panel p-6 md:p-8">
    <h2 class="font-display text-2xl uppercase">Want these drops in real time?</h2>
    <p class="mt-2 text-sm leading-6 text-ppq-muted">Follow the playlist and check update posts for fresh adds, rotation notes, and merch announcements.</p>
    <div class="mt-4 flex flex-wrap gap-3">
      <%= link_to "Open on Spotify", platform_urls[:spotify], class: "inline-flex items-center justify-center rounded-full border border-ppq-red bg-gradient-to-r from-ppq-yellow to-ppq-red px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition hover:brightness-95", target: "_blank", rel: "noopener", data: { analytics_event: "click_spotify" } %>
      <%= link_to "Read all updates", updates_path, class: "inline-flex items-center justify-center rounded-full border border-ppq-ink px-6 py-3 text-sm font-semibold uppercase tracking-wide text-ppq-ink transition hover:bg-ppq-cream" %>
    </div>
  </div>
</section>
