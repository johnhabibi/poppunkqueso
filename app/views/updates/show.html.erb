<article class="mx-auto max-w-4xl px-4 pb-16 pt-14" data-analytics-view="open_update_post" data-analytics-props="<%= { content_slug: @update.slug }.to_json %>">
  <p class="text-xs uppercase tracking-wide text-ppq-red"><%= @update.date.strftime("%B %-d, %Y") %></p>
  <h1 class="mt-3 font-display text-4xl uppercase leading-tight md:text-5xl"><%= @update.title %></h1>
  <p class="mt-4 text-lg leading-8 text-ppq-muted"><%= @update.intro %></p>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    <section class="rounded-2xl border border-ppq-ink/10 bg-white p-5">
      <h2 class="font-display text-xl uppercase">Featured tracks</h2>
      <ul class="mt-3 space-y-2 text-sm leading-6 text-ppq-muted">
        <% @update.featured_tracks.each do |track| %>
          <li>• <%= track %></li>
        <% end %>
      </ul>
    </section>

    <section class="rounded-2xl border border-ppq-ink/10 bg-white p-5">
      <h2 class="font-display text-xl uppercase">Bands added</h2>
      <ul class="mt-3 space-y-2 text-sm leading-6 text-ppq-muted">
        <% @update.bands_added.each do |band| %>
          <li>• <%= band %></li>
        <% end %>
      </ul>
    </section>
  </div>

  <section class="prose-custom mt-8 space-y-4 rounded-2xl border border-ppq-ink/10 bg-white p-6">
    <%= render_content_blocks(@update.body) %>
  </section>

  <% if @update.closing_cta.present? %>
    <section class="mt-8 rounded-2xl border border-ppq-ink/10 bg-white p-6">
      <p class="text-base leading-7"><%= @update.closing_cta %></p>
      <div class="mt-4">
        <%= render "shared/platform_buttons", stacked: false %>
      </div>
    </section>
  <% end %>

  <section class="mt-8 rounded-2xl border border-ppq-ink/10 bg-white p-6">
    <h2 class="font-display text-2xl uppercase">Keep digging</h2>
    <div class="mt-3 flex flex-wrap gap-4 text-sm font-semibold">
      <%= link_to "Go to Listen", listen_path, class: "text-ppq-red underline-offset-2 hover:underline" %>
      <%= link_to "Read all updates", updates_path, class: "text-ppq-red underline-offset-2 hover:underline" %>
      <%= link_to "Read featured article", article_path("best-newer-pop-punk-songs"), class: "text-ppq-red underline-offset-2 hover:underline" %>
    </div>
  </section>
</article>
